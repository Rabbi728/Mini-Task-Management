generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model activity_logs {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @db.Uuid
  record_type String   @db.VarChar(16)
  details     String
  created_by  Int?
  created_at  DateTime
  updated_at  DateTime
  users       users?   @relation(fields: [created_by], references: [id], onUpdate: SetNull)
}

model personal_access_tokens {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @db.VarChar(64)
  expires_at DateTime @db.Timestamp(6)
  created_at DateTime @db.Timestamp(6)
  updated_at DateTime @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token], map: "personal_access_tokens_token")
}

model tasks {
  id                               Int         @id @default(autoincrement())
  uuid                             String      @unique @db.Uuid
  title                            String      @db.VarChar(191)
  description                      String
  assigned_user                    Int?
  status                           task_status
  created_by                       Int?
  created_at                       DateTime
  updated_at                       DateTime
  users_tasks_assigned_userTousers users?      @relation("tasks_assigned_userTousers", fields: [assigned_user], references: [id], onUpdate: SetNull)
  users_tasks_created_byTousers    users?      @relation("tasks_created_byTousers", fields: [created_by], references: [id], onUpdate: SetNull)
}

model users {
  id                               Int                      @id @default(autoincrement())
  uuid                             String                   @unique @db.Uuid
  name                             String                   @db.VarChar(64)
  email                            String                   @unique @db.VarChar(191)
  role                             String                   @db.VarChar(16)
  password                         String                   @db.VarChar(191)
  created_at                       DateTime
  updated_at                       DateTime
  activity_logs                    activity_logs[]
  personal_access_tokens           personal_access_tokens[]
  tasks_tasks_assigned_userTousers tasks[]                  @relation("tasks_assigned_userTousers")
  tasks_tasks_created_byTousers    tasks[]                  @relation("tasks_created_byTousers")
}

enum task_status {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}
